# Application
NEXT_PUBLIC_SITE_URL=https://persiantoolbox.ir
NEXT_PUBLIC_SITE_NAME="جعبه ابزار فارسی"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/analytics
ANALYTICS_STORAGE=postgres
ANALYTICS_DATA_DIR=var/analytics
ANALYTICS_INGEST_SECRET=
ANALYTICS_MAX_BODY_BYTES=262144
ANALYTICS_RATE_LIMIT=120
ANALYTICS_RATE_WINDOW_MS=60000

# App storage & auth
APP_DATA_DIR=var/app
DATABASE_URL=postgresql://user:password@localhost:5432/persian_tools
SESSION_TTL_DAYS=7
SUBSCRIPTION_WEBHOOK_SECRET=
ADMIN_EMAIL_ALLOWLIST=admin@example.com
OPS_DASHBOARD_TOKEN=

# Support Links
NEXT_PUBLIC_SUPPORT_ONETIME_URL=
NEXT_PUBLIC_SUPPORT_MONTHLY_URL=
NEXT_PUBLIC_SUPPORT_SPONSOR_URL=

# Developer Attribution Links (Footer + Admin)
DEVELOPER_NAME="علیرضا صفایی"
DEVELOPER_BRAND_TEXT="این وب‌سایت توسط علیرضا صفایی توسعه داده شده است."
ORDER_URL=
PORTFOLIO_URL=

# AI Assistant (Optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_BASE_URL=
DEEPSEEK_INPUT_PRICE_PER_1M=
DEEPSEEK_OUTPUT_PRICE_PER_1M=
OPENROUTER_INPUT_PRICE_PER_1M=
OPENROUTER_OUTPUT_PRICE_PER_1M=
OPENAI_INPUT_PRICE_PER_1M=
OPENAI_OUTPUT_PRICE_PER_1M=
# Optional branding for OpenRouter headers
SITE_URL=https://persiantoolbox.ir
SITE_NAME="Persian Toolbox"

# Feature Flags
FEATURE_DASHBOARD_ENABLED=0
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_FEATURE_V3_NAV=0
FEATURE_V3_REDIRECTS=0
FEATURE_V3_ANALYTICS_POLICY=0

# Ops window scheduler (optional)
OPS_WINDOW_REPEAT=6
OPS_WINDOW_INTERVAL_MS=30000
OPS_DEGRADED_WEBHOOK=
