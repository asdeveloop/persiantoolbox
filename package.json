{
  "name": "persiantoolbox",
  "private": false,
  "version": "3.0.6",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm generate:og && next build",
    "build:lib": "tsup",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ci": "pnpm lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check",
    "test": "vitest",
    "test:ci": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ci": "PLAYWRIGHT_SKIP_FIREFOX=1 PLAYWRIGHT_DISABLE_VIDEO=1 playwright test --project=chromium --reporter=list",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format:check": "prettier --check .",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "ci:quick": "pnpm lint && pnpm typecheck && pnpm gate:local-first && pnpm vitest --run",
    "smoke:local": "node scripts/quality/run-local-smoke.mjs",
    "predeploy:smoke": "SMOKE_HOST=127.0.0.1 SMOKE_PORT=3100 pnpm smoke:local",
    "ci:contracts": "pnpm monetization:review:validate && pnpm monetization:ops:validate && pnpm monetization:alerting:validate && pnpm monetization:site-settings:validate && pnpm feature-flags:audit && pnpm deploy:readiness:validate && pnpm release:rc:validate && pnpm release:rollback:validate && pnpm release:launch:validate && pnpm release:state:validate && pnpm pwa:shell:check && pnpm pwa:sw:validate && pnpm quality:links:check && pnpm quality:docs-links:check && pnpm licensing:validate",
    "bench": "vitest bench",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "analyze": "ANALYZE=true next build",
    "start:prod": "next start -p 3000",
    "lighthouse": "pnpm dlx lighthouse http://localhost:3000 --output html --output-path ./reports/lighthouse/report.html",
    "lighthouse:ci": "pnpm dlx @lhci/cli@0.13.0 autorun && node scripts/quality/summarize-lighthouse-ci.mjs",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:api": "typedoc",
    "docs:auto": "node scripts/docs/sync-docs.mjs",
    "docs:auto:check": "node scripts/docs/sync-docs.mjs --check",
    "release": "semantic-release",
    "generate:og": "node scripts/generate-og-images.mjs",
    "gate:local-first": "tsx scripts/quality/verify-local-first.ts",
    "gate:deploy": "node scripts/quality/verify-np0-tasks.mjs",
    "performance:budgets": "node scripts/quality/check-performance-budgets.mjs",
    "feature-flags:audit": "pnpm exec tsx scripts/quality/audit-feature-flags.ts",
    "security:scan": "pnpm audit --prod --audit-level=high --ignore-registry-errors",
    "security:secrets": "node scripts/security/scan-secrets.mjs",
    "db:migrate": "node scripts/db/migrate.mjs",
    "deploy:readiness:validate": "node scripts/deploy/validate-readiness-gates.mjs",
    "deploy:readiness:run": "node scripts/deploy/run-readiness-gates.mjs --tier=core",
    "deploy:readiness:summary": "node scripts/deploy/generate-readiness-summary.mjs",
    "deploy:edge:check": "node scripts/deploy/check-edge-connectivity.mjs",
    "release:readiness:local": "node scripts/deploy/run-local-release-readiness.mjs",
    "deploy:post:report": "node scripts/deploy/generate-post-deploy-report.mjs",
    "deploy:env:encode": "bash scripts/deploy/encode-env-file.sh",
    "deploy:nginx:provision": "bash scripts/deploy/provision-nginx-site.sh",
    "admin:ops:snapshot": "node scripts/admin/generate-ops-snapshot.mjs",
    "admin:ops:window": "node scripts/admin/generate-ops-snapshot.mjs --base-url https://persiantoolbox.ir --repeat=6 --interval-ms=30000 --require-healthy --include-output",
    "admin:ops:window:local": "node scripts/admin/generate-ops-snapshot.mjs --base-url http://127.0.0.1:3000 --repeat=6 --interval-ms=30000 --require-healthy --include-output",
    "admin:ops:window:cron": "node scripts/admin/run-ops-window.mjs",
    "release:rc:validate": "node scripts/release/validate-rc-checklist.mjs",
    "release:rollback:validate": "node scripts/release/validate-rollback-drill.mjs",
    "release:rc:run": "node scripts/release/run-rc-gates.mjs --tier=core",
    "release:launch:validate": "node scripts/release/validate-launch-day-checklist.mjs",
    "release:state:validate": "node scripts/release/validate-release-state-consistency.mjs",
    "release:launch:run": "node scripts/release/run-launch-smoke.mjs --tier=core",
    "release:workflow:snapshot": "node scripts/release/snapshot-workflow-run.mjs --workflow deploy-production --branch main",
    "pwa:sw:validate": "node scripts/pwa/validate-sw-version.mjs",
    "pwa:shell:generate": "pnpm exec tsx scripts/pwa/generate-shell-assets.ts",
    "pwa:shell:check": "pnpm exec tsx scripts/pwa/generate-shell-assets.ts --check",
    "quality:links:check": "node scripts/quality/check-internal-links.mjs",
    "quality:docs-links:check": "node scripts/quality/check-doc-links.mjs",
    "monetization:review:validate": "node scripts/monetization/validate-review-backlog.mjs",
    "monetization:ops:validate": "node scripts/monetization/validate-operations-checklist.mjs",
    "monetization:alerting:validate": "node scripts/monetization/validate-alerting-decision-rules.mjs",
    "monetization:site-settings:validate": "node scripts/monetization/validate-site-settings-contract.mjs",
    "monetization:close:monthly": "node scripts/monetization/run-monthly-close.mjs",
    "monetization:close:quarterly": "node scripts/monetization/run-quarterly-close.mjs",
    "monetization:close:all": "node scripts/monetization/run-close-all.mjs",
    "licensing:consistency": "node scripts/licensing/validate-license-consistency.mjs",
    "licensing:validate": "node scripts/licensing/validate-license-assets.mjs && node scripts/licensing/validate-license-consistency.mjs",
    "licensing:release:dry-run": "node scripts/licensing/run-v2-release-prep-dry-run.mjs",
    "load:burst": "node scripts/load/run-burst.mjs",
    "roadmap:next": "node scripts/roadmap/next-task.mjs --format table",
    "roadmap:phase0": "node scripts/roadmap/execute.mjs --phase phase0-verify",
    "roadmap:np0": "node scripts/roadmap/execute.mjs --phase np0",
    "roadmap:vps": "node scripts/roadmap/execute.mjs --phase vps-check",
    "roadmap:run": "node scripts/roadmap/execute.mjs --phase full",
    "roadmap:dry": "node scripts/roadmap/execute.mjs --phase full --dry-run",
    "codex:bootstrap": "node scripts/codex/bootstrap.mjs",
    "codex:doctor": "node scripts/codex/bootstrap.mjs --check",
    "ai:ask": "tsx scripts/ai/ask.ts",
    "handoff:status": "node scripts/handoff-status.mjs"
  },
  "codex": {
    "mcp-start": "bash scripts/mcp-start.sh"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "next": "^16.2.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@next/bundle-analyzer": "^16.2.4",
    "@openai/codex-shell-tool-mcp": "^0.116.0",
    "@playwright/test": "^1.51.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-essentials": "9.0.0-alpha.12",
    "@storybook/addon-interactions": "9.0.0-alpha.10",
    "@storybook/addon-links": "9.0.0-alpha.12",
    "@storybook/nextjs": "9.0.0-alpha.12",
    "@storybook/react": "9.0.0-alpha.12",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "playwright-core": "1.58.1",
    "postcss": "^8.5.10",
    "prettier": "^3.2.5",
    "semantic-release": "^23.0.8",
    "storybook": "9.0.0-alpha.12",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.6",
    "typescript": "5.9.3",
    "vitest": "^1.6.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./numbers": {
      "types": "./dist/numbers/index.d.ts",
      "import": "./dist/numbers/index.mjs",
      "require": "./dist/numbers/index.js"
    },
    "./localization": {
      "types": "./dist/localization/index.d.ts",
      "import": "./dist/localization/index.mjs",
      "require": "./dist/localization/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.mjs",
      "require": "./dist/validation/index.js"
    },
    "./finance": {
      "types": "./dist/finance.d.ts",
      "import": "./dist/finance.mjs",
      "require": "./dist/finance.js"
    },
    "./date-tools": {
      "types": "./dist/date-tools.d.ts",
      "import": "./dist/date-tools.mjs",
      "require": "./dist/date-tools.js"
    }
  },
  "typesVersions": {
    "*": {
      "numbers": [
        "dist/numbers/index.d.ts"
      ],
      "localization": [
        "dist/localization/index.d.ts"
      ],
      "validation": [
        "dist/validation/index.d.ts"
      ],
      "finance": [
        "dist/finance.d.ts"
      ],
      "date-tools": [
        "dist/date-tools.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "description": "A comprehensive collection of free online tools for Persian speakers - PDF tools, financial calculators, image processing. Client-side processing for privacy and security.",
  "keywords": [
    "persian",
    "farsi",
    "tools",
    "pdf",
    "calculator",
    "image",
    "online",
    "free",
    "privacy",
    "offline"
  ],
  "author": "Persian Tools Team",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/parsairaniiidev/persiantoolbox.git"
  },
  "bugs": {
    "url": "https://github.com/parsairaniiidev/persiantoolbox/issues"
  },
  "homepage": "https://persiantoolbox.ir",
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": "1.29.0",
      "lodash": "4.17.23",
      "hono": "4.11.7",
      "playwright-core": "1.58.1"
    }
  }
}
